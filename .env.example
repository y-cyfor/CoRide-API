# CoRide-API 环境变量配置
# 复制此文件为 .env 并修改对应值

# 管理员账号（首次启动时生效，已存在则跳过）
CORIDE_ADMIN_USERNAME=admin
CORIDE_ADMIN_PASSWORD=admin123

# JWT 签名密钥（务必使用随机字符串，生产环境不要使用默认值）
CORIDE_JWT_SECRET=change-me-to-a-random-secret

# 日志级别: trace / debug / info / warn / error
CORIDE_LOG_LEVEL=info

# 服务端口（默认 8000）
# CORIDE_PORT=8000

# 数据库路径（Docker 部署时映射到 volume）
# CORIDE_DB_PATH=/app/data/coride.db
